{
  "name": "Consumer Complaints Dark Cyan Amber Theme",
  "dataColors": [
    "#25D0D9",
    "#2F80ED",
    "#F59E0B",
    "#7C3AED",
    "#B8D8C0",
    "#FF4D4D"
  ],
  "background": "#0B0F0E",
  "foreground": "#FFFFFF",
  "tableAccent": "#25D0D9",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#121C18"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#25D0D9"
              }
            },
            "radius": 6
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            },
            "background": {
              "solid": {
                "color": "#121C18"
              }
            }
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#25D0D9"
              }
            },
            "fill": {
              "solid": {
                "color": "#25D0D9"
              }
            }
          }
        ],
        "lineStyles": [
          {
            "strokeColor": {
              "solid": {
                "color": "#25D0D9"
              }
            },
            "strokeWidth": 3
          }
        ],
        "legend": [
          {
            "labelColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            },
            "titleColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            },
            "gridlineColor": {
              "solid": {
                "color": "#33433A"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            },
            "gridlineColor": {
              "solid": {
                "color": "#33433A"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#0B0F0E"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#0B0F0E"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#25D0D9"
              }
            },
            "fontSize": 24
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#B8D8C0"
              }
            }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#0B0F0E"
              }
            },
            "background": {
              "solid": {
                "color": "#D9F7FF"
              }
            }
          }
        ],
        "header": [
          {
            "fontColor": {
              "solid": {
                "color": "#B8D8C0"
              }
            }
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#25D0D9"
              }
            }
          }
        ],
        "lineStyles": [
          {
            "strokeColor": {
              "solid": {
                "color": "#25D0D9"
              }
            },
            "strokeWidth": 3
          }
        ]
      }
    },
    "clusteredBarChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#2F80ED"
              }
            },
            "fill": {
              "solid": {
                "color": "#2F80ED"
              }
            }
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#2F80ED"
              }
            },
            "fill": {
              "solid": {
                "color": "#2F80ED"
              }
            }
          }
        ]
      }
    },
    "pieChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#7C3AED"
              }
            }
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": {
              "solid": {
                "color": "#7C3AED"
              }
            }
          }
        ]
      }
    }
  }
}
